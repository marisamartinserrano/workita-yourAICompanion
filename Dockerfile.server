FROM node:22-alpine AS builder
WORKDIR /app
COPY package*.json ./
RUN npm ci
COPY server/ ./server/
COPY tsconfig.json ./
COPY server/tsconfig.json ./server/tsconfig.json
RUN npx tsc -p server/tsconfig.json

FROM node:22-alpine
WORKDIR /app
COPY package*.json ./
RUN npm ci --omit=dev
COPY --from=builder /app/dist/server ./server
EXPOSE 3001
CMD ["node", "server/index.js"]
